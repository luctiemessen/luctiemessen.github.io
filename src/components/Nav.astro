---
// data imports
import navData from "../data/navData";
---
<!-- Desktop/tablet: floating pill nav -->
<header class="site-header">
    <div class="nav-container" id="nav-container">
        <nav aria-label="Primary navigation" class="glass-pill pill-nav">
            <a href="/" class="nav-home">Luc Tiemessen</a>
            <div class="nav-items">
                {navData.map((item) => (
                    <a href={item.path} data-navLink>{item.name}</a>
                ))}
            </div>
        </nav>
        <a class="scroll-drip glass-pill" href="#" id="scroll-to-top" aria-label="Scroll to top">
            <span class="material-symbols-outlined" aria-hidden="true">north</span>
        </a>
    </div>
</header>

<!-- Mobile: bottom-right controls -->
<div class="mobile-controls" id="mobile-controls">
    <button
        class="mobile-hamburger glass-pill"
        id="hamburger-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
    >
        <span></span>
        <span></span>
        <span></span>
    </button>
    <a class="mobile-scroll-top glass-pill" href="#" id="mobile-scroll-top-btn" aria-label="Scroll to top">
        <span class="material-symbols-outlined" aria-hidden="true">north</span>
    </a>
    <nav class="mobile-menu glass-pill" id="mobile-menu" aria-label="Mobile navigation" aria-hidden="true">
        <a href="/" data-navLink tabindex="-1">Home</a>
        {navData.map((item) => (
            <a href={item.path} data-navLink tabindex="-1">{item.name}</a>
        ))}
    </nav>
</div>

<script>
    import "../js/nav.js"
</script>
